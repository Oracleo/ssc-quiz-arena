# Environment Variables for Production
# Do NOT commit this file to GitHub - add to .gitignore
# Copy this to .env.local and fill in your values

# ========= FIREBASE CREDENTIALS =========
# Get these from Firebase Console → Project Settings → Web Configuration
FIREBASE_API_KEY=your_api_key_here
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_STORAGE_BUCKET=your_storage_bucket.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_web_app_id
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
DATABASE_URL=https://your_project.firebaseio.com

# ========= VERCEL DEPLOYMENT =========
VERCEL_TOKEN=your_vercel_token_here
VERCEL_ORG_ID=your_org_id_here
VERCEL_PROJECT_ID=your_project_id_here

# ========= GOOGLE PLAY STORE =========
# Base64 encoded service account JSON (for CI/CD)
PLAY_STORE_SERVICE_ACCOUNT=your_service_account_json_base64_here

# Android Signing (CI/CD)
KEYSTORE_PASSWORD=your_keystore_password
KEY_ALIAS=ssc_quiz_arena_key
KEY_PASSWORD=your_key_password

# ========= APPLICATION =========
APP_NAME=SSC Quiz Arena
APP_VERSION=1.0.0
BUILD_NUMBER=1
APP_BUNDLE_ID=com.sscquizarena.app

# ========= API CONFIGURATION =========
API_TIMEOUT_SECONDS=30
CACHE_DURATION_HOURS=24

# ========= FEATURE FLAGS =========
ENABLE_ANALYTICS=true
ENABLE_CRASH_REPORTING=true
DEBUG_MODE=false
